# Async application connection used by FastAPI.
DATABASE_URL=postgresql+asyncpg://localhost:5432/sentinel_ai

# Synchronous connection used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://localhost:5432/sentinel_ai

ENVIRONMENT=development
# Use an exact JSON list of browser origins. For Vercel/Railway, replace this
# with the deployed frontend URL, for example ["https://sentinel-ai.vercel.app"].
ALLOWED_ORIGINS=["http://localhost:3000"]

# Redis is reserved for the asynchronous scan job queue.
REDIS_URL=redis://localhost:6379/0

# Local clone/snapshot prepared by ingestion. Never point this at a production checkout.
REMEDIATION_REPOSITORY_ROOT=

# Repository ingestion limits. LOCAL is development/test-only and must stay blank in production.
INGESTION_MAX_REPOSITORY_BYTES=524288000
INGESTION_CLONE_TIMEOUT_SECONDS=90
INGESTION_LOCAL_REPOSITORY_ROOT=

# Local Markdown report export directory for the MVP.
REPORT_EXPORT_DIRECTORY=exports

# AI Reasoning Layer. Gemini is the default provider. API keys are read only at runtime.
AI_REASONING_PROVIDER=gemini
GEMINI_API_KEY=
# Current free-tier model. Set gemini-3.1-flash-lite if this preview is unavailable.
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=20
# Avoid free-tier request bursts. Retry only transient/rate-limit failures.
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=12
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_INITIAL_DELAY_SECONDS=10

# Optional OpenAI alternative. Set AI_REASONING_PROVIDER=openai to use it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=20
AI_CONTEXT_LINES=12

# GitHub OAuth. Generate a long random SESSION_SECRET before deploying.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
# Browser location to return to after the server-side OAuth callback.
FRONTEND_URL=http://localhost:3000
# Includes repo so a user-approved Sentinel branch can be pushed and opened as a PR.
GITHUB_OAUTH_SCOPES="read:user user:email repo"
SESSION_SECRET=replace-with-a-long-random-secret
# Required for a frontend and API hosted on different HTTPS origins. For
# plain local HTTP development only, set SESSION_HTTPS_ONLY=false in .env.
SESSION_SAME_SITE=none
SESSION_HTTPS_ONLY=true

# Fernet key used only to encrypt GitHub tokens at rest. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=
